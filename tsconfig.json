{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "es2024",
		"moduleDetection": "force",
		"noImplicitAny": false,
		"strict": true,
		"moduleResolution": "Bundler",
		"module": "es2022",
		"noEmit": true,
		"lib": ["es2024"],
		"types": ["./worker-configuration.d.ts", "@types/node"]
	},
	"exclude": ["node_modules", "dist"],
	"include": ["src", "worker-configuration.d.ts"]
}
